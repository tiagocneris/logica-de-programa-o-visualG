Algoritmo "Consumo"

Var

     distancia : inteiro
     combustivel, consumo : real
   
Inicio

     escreva("Distancia Percorrida: ")
     leia(distancia)
     escreva("Combustível Gasto: ")
     leia(combustivel)

     consumo <- distancia / combustivel
     
     escreval ("Consumo medio = ", consumo:6:3)
     
Fimalgoritmo